+] as const;
+const OZ_TO_GAL = 1 / 128;
+
+async function appendDrinkEntry(gallons: number, label: string): Promise<void> {
+  const today = new Date().toISOString().split("T")[0];
+  const raw = (await AsyncStorage.getItem(`log_${today}`)) ?? "[]";
+  let list: { label: string; gallons: number; time: string; icon?: string }[];
+  try {
+    list = JSON.parse(raw);
+    if (!Array.isArray(list)) list = [];
+  } catch {
+    list = [];
   }
+  const time = new Date().toLocaleTimeString([], {
+    hour: "2-digit",
+    minute: "2-digit",
+  });
+  list.push({ label, gallons, time, icon: "🥤" });
+  await AsyncStorage.setItem(`log_${today}`, JSON.stringify(list));
+}
