+// ─── HEALTH SCREENS ─────────────────────────────────────
+// Health tabs share the underlying intake log with the Conservation Logger
+// (single source of truth in AsyncStorage `log_<YYYY-MM-DD>`), but only
+// surface drink-type entries. Watering the plant is a side effect of any
+// drink logged in either mode.
+const DRINK_PRESETS = [
+  { label: "Glass", oz: 8, icon: "🥛" },
+  { label: "Bottle", oz: 16, icon: "🍶" },
