+            </Text>
+          </View>
+        </View>
+
+        <View
+          style={[
+            st.glassCard,
+            { marginHorizontal: 16, marginBottom: 14 },
+          ]}
+        >
+          <View
+            style={{
+              flexDirection: "row",
+              alignItems: "center",
+              gap: 12,
+              marginBottom: 10,
+            }}
+          >
+            <PlantArt stage={stage} size={44} />
+            <View style={{ flex: 1 }}>
+              <Text
+                style={{
+                  color: C.white,
+                  fontSize: 14,
+                  fontWeight: "800",
+                }}
+              >
+                Plant hydration
+              </Text>
+              <Text style={{ color: C.muted, fontSize: 11, marginTop: 2 }}>
+                {Math.round(hydration)}% — every drink helps
+              </Text>
+            </View>
+          </View>
+          <HydrationBar pct={hydration} />
+        </View>
+
+        <Text style={s.section}>QUICK ADD</Text>
+        <View
+          style={{
+            flexDirection: "row",
+            gap: 10,
+            paddingHorizontal: 16,
+            marginBottom: 12,
+          }}
+        >
+          {DRINK_PRESETS.map((p) => (
+            <Press
+              key={p.label}
+              onPress={() => drink(p.oz, p.label)}
+              style={[
+                st.actCard,
+                { width: undefined, flex: 1, minHeight: 100 },
+              ]}
+            >
+              <Text style={{ fontSize: 32 }}>{p.icon}</Text>
+              <Text style={st.actLabel}>{p.label}</Text>
+              <Text style={st.actGallons}>{p.oz} oz</Text>
+            </Press>
