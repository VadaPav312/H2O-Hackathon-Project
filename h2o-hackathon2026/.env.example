# =============================================================================
# h2otoyou — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your own values.
#   cp .env.example .env.local
#
# `.env.local` is gitignored and must NEVER be committed — it holds secrets.
# Variables prefixed EXPO_PUBLIC_ are bundled into the client app and are
# therefore PUBLIC. Everything else is server-side only (Vercel /api functions)
# and must stay secret.
# =============================================================================


# -----------------------------------------------------------------------------
# Client app (Expo) — public, baked into the build
# -----------------------------------------------------------------------------

# Base URLs for the Vercel serverless proxies the app calls.
# Point these at your own Vercel deployment (e.g. https://<your-app>.vercel.app).
EXPO_PUBLIC_GROQ_PROXY_URL="https://your-app.vercel.app/api/groq"
EXPO_PUBLIC_CDEC_PROXY_URL="https://your-app.vercel.app/api/cdec"
EXPO_PUBLIC_NEWSLETTER_BASE_URL="https://your-app.vercel.app/api/newsletter"

# Google OAuth web client ID (Google Cloud Console → Credentials → OAuth client).
# Used for Google sign-in via Firebase.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=""


# -----------------------------------------------------------------------------
# Server-side secrets — Vercel /api functions only. Keep private.
# Set these in the Vercel dashboard (Project → Settings → Environment Variables)
# for deployments, and here in .env.local for local `vercel dev`.
# -----------------------------------------------------------------------------

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=""

# Resend (transactional + newsletter email) — https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="newsletter@yourdomain.com"

# Resend audience IDs — https://resend.com/audiences
RESEND_AUDIENCE_WEEKLY_ID=""
RESEND_AUDIENCE_MONTHLY_ID=""

# Shared secret protecting the newsletter cron endpoint (any long random string).
CRON_SECRET=""


# -----------------------------------------------------------------------------
# Auto-provided by Vercel at build/runtime — no need to set manually.
# Listed here for reference only:
#   VERCEL_OIDC_TOKEN              (generated by `vercel env pull` / Vercel CLI)
#   VERCEL_PROJECT_PRODUCTION_URL  (injected by Vercel on deploy)
# -----------------------------------------------------------------------------
